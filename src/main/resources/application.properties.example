spring.application.name=tracker
server.port=8080

spring.datasource.url=jdbc:mysql://localhost:3307/your_database_name
spring.datasource.username=your_mysql_username
spring.datasource.password=your_mysql_password
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

spring.jpa.hibernate.ddl-auto=validate
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect

app.jwt.secret=your_256bit_secret_key_here
app.jwt.expiration=86400000

alphavantage.api.key=your_alpha_vantage_api_key
alphavantage.base.url=https://www.alphavantage.co/query

scheduler.enabled=true